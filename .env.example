DATABASE_URL=postgresql://user:password@host/db?sslmode=require
MSSQL_CONNECTION_STRING=DRIVER={ODBC Driver 17 for SQL Server};SERVER=host;DATABASE=StayMatchDb;UID=user;PWD=password
SYNC_INTERVAL_MINUTES=5
API_KEY=your-secret-api-key-here
LOG_LEVEL=INFO

# .NET Property API Configuration
PROPERTY_API_BASE_URL=https://your-dotnet-api.com
PROPERTY_API_TOKEN=your-dotnet-api-token

# JWT Authentication Configuration
JWT_SECRET=your-jwt-secret-key
JWT_ISSUER=your-jwt-issuer
JWT_AUDIENCE=your-jwt-audience